# Bot token from @BotFather (Telegram) — /newbot, then copy the token here.
TELEGRAM_BOT_TOKEN=

# Where the ytplayer API's /enqueue endpoint is reachable.
# Defaults to http://localhost:8000/enqueue if unset.
ENQUEUE_URL=http://localhost:8000/enqueue

# Must match ADMIN_USERNAME / ADMIN_PASSWORD in the main app's .env — used
# to authenticate as admin (bypassing song validation) for messages from
# ADMIN_TELEGRAM_IDS below.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Comma-separated numeric Telegram user IDs (get yours from @userinfobot)
# whose song requests skip all validation (age/category/duration) and go
# straight to the queue.
ADMIN_TELEGRAM_IDS=123456789
