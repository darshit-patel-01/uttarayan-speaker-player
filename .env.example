KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_TOPIC=youtube-audio-queue
KAFKA_GROUP_ID=youtube-audio-player
KAFKA_MAX_POLL_INTERVAL_MS=21600000

# Redis backs real_time_validation/'s per-requester rate limiting. Port 6380
# (not Redis's default 6379) to avoid colliding with any other Redis-
# compatible server already running on the host — see docker-compose.yml.
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_DB=0

# Max songs a single requester (phone number, Telegram id, or IP for plain
# web requests) may enqueue within RATE_LIMIT_WINDOW_SECONDS. Admins are
# exempt, same as the other validation checks.
RATE_LIMIT_MAX_SONGS=3
RATE_LIMIT_WINDOW_SECONDS=3600

MAX_DURATION_SECONDS=7200

# Loudness normalization (ffplay -af loudnorm) so songs at different
# recording volumes play at a consistent perceived level.
NORMALIZE_VOLUME=true
LOUDNORM_TARGET_LUFS=-16

# Crossfade: seconds before a song's natural end that the next song's TTS
# announcement starts, overlapping the outgoing song's tail.
CROSSFADE_LEAD_SECONDS=8
